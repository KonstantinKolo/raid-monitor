@inherits LayoutComponentBase
@using MudBlazor

<style>
    @@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@500;700&display=swap');

    .top-bar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 52px;
        background: rgba(10,10,15,0.95);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        padding: 0 24px;
        gap: 10px;
        z-index: 1000;
        backdrop-filter: blur(12px);
    }

    .top-bar-logo {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }

    .top-bar-version {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        color: #333;
        letter-spacing: 0.1em;
        padding: 2px 8px;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 4px;
    }

    .main-content {
        padding-top: 52px;
        background: #0a0a0f;
        min-height: 100vh;
    }
</style>

<div class="top-bar">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="color:#00ff88;">
        <rect x="2" y="3" width="20" height="4" rx="1" fill="currentColor" opacity="0.9"/>
        <rect x="2" y="10" width="20" height="4" rx="1" fill="currentColor" opacity="0.6"/>
        <rect x="2" y="17" width="20" height="4" rx="1" fill="currentColor" opacity="0.35"/>
        <circle cx="19" cy="5" r="1" fill="#0a0a0f"/>
        <circle cx="19" cy="12" r="1" fill="#0a0a0f"/>
        <circle cx="19" cy="19" r="1" fill="#0a0a0f"/>
    </svg>
    <span class="top-bar-logo">RAID Monitor</span>
    <span class="top-bar-version">V1 · DEV</span>
</div>

<div class="main-content">
    @Body
</div>